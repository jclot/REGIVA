@model REGIVA_CR.AB.ModelosParaUI.Blog.BlogDto
@{ Layout = "_Layout"; ViewData["Title"] = Model.Id == 0 ? "Nuevo Blog" : "Editar Blog"; }

<div class="page-header">
    <div class="container-xl">
        <h2 class="page-title">@ViewData["Title"]</h2>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <form asp-action="Save" method="post" id="blogForm">
            <input type="hidden" asp-for="Id" />
            
            <div class="row">
                <div class="col-lg-9 mx-auto">
                    
                    <div class="card mb-4 shadow-sm">
                        <div class="card-body">
                            <div class="mb-1">
                                <label asp-for="Title" class="form-label text-muted text-uppercase small fw-bold">Título del Artículo</label>
                                <input asp-for="Title" class="form-control form-control-lg border-0 ps-2 fs-1 fw-bold" placeholder="Escribe un título impactante..." style="box-shadow:none;" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4 shadow-sm border-0 overflow-hidden">
                        
                        <div class="card-header border-bottom py-3 sticky-top" style="z-index: 10;">
                            <div class="d-flex flex-wrap justify-content-center gap-2 w-100">
                                
                                <div class="btn-group shadow-sm rounded-2">
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('undo')" title="Deshacer"><i class="bi bi-arrow-counterclockwise fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('redo')" title="Rehacer"><i class="bi bi-arrow-clockwise fs-2"></i></button>
                                </div>

                                <div class="vr mx-1 my-auto h-50"></div>

                                <div class="btn-group shadow-sm rounded-2">
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('bold')" title="Negrita"><i class="bi bi-type-bold fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('italic')" title="Cursiva"><i class="bi bi-type-italic fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('underline')" title="Subrayado"><i class="bi bi-type-underline fs-2"></i></button>
                                </div>

                                <div class="btn-group shadow-sm rounded-2">
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('formatBlock', 'P')" title="Párrafo"><i class="bi bi-paragraph fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('formatBlock', 'H2')" title="Título 2"><i class="bi bi-type-h2 fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('formatBlock', 'H3')" title="Título 3"><i class="bi bi-type-h3 fs-2"></i></button>
                                </div>

                                <div class="btn-group shadow-sm rounded-2">
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('insertUnorderedList')" title="Viñetas"><i class="bi bi-list-ul fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('insertOrderedList')" title="Numeración"><i class="bi bi-list-ol fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('insertHorizontalRule')" title="Separador"><i class="bi bi-hr fs-2"></i></button>
                                </div>

                                <div class="btn-group shadow-sm rounded-2">
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" id="btnOpenLinkModal" onmousedown="event.preventDefault()" title="Insertar Enlace"><i class="bi bi-link-45deg fs-2"></i></button>
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('unlink')" title="Quitar Enlace"><i class="bi bi-link-45deg text-danger fs-2"></i></button>
                                </div>
                                
                                <div class="btn-group shadow-sm rounded-2 ms-auto">
                                    <button type="button" class="btn btn-icon btn-ghost-secondary" onclick="execCmd('removeFormat')" title="Limpiar Formato"><i class="bi bi-eraser-fill fs-2 text-muted"></i></button>
                                </div>

                            </div>
                        </div>

                        <div id="editor-area" class="editor-content p-5 fs-4" style="line-height: 1.8;" contenteditable="true" spellcheck="false">
                            <p class="text-muted">Escribe tu historia aquí...</p>
                        </div>
                    </div>

                    <textarea asp-for="ContentHtml" id="hiddenContent" style="display:none;"></textarea>
                    <span asp-validation-for="ContentHtml" class="text-danger"></span>

                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <label asp-for="Summary" class="form-label fw-bold">Resumen Corto (SEO)</label>
                                    <textarea asp-for="Summary" class="form-control" rows="2" placeholder="Este texto aparecerá en las tarjetas..."></textarea>
                                    <span asp-validation-for="Summary" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <div class=" p-3 rounded-3 text-center">
                                        <label class="form-check form-switch d-inline-block mb-3">
                                            <input class="form-check-input" type="checkbox" asp-for="IsPublished">
                                            <span class="form-check-label fw-bold">Publicar Visiblemente</span>
                                        </label>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Index" class="btn btn-ghost-secondary">Cancelar</a>
                                            <button type="submit" class="btn btn-primary px-4">Guardar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal modal-blur fade" id="modal-insert-link" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Insertar Enlace</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">URL del sitio web</label>
                <input type="text" class="form-control" id="linkUrlInput" placeholder="https://google.com">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn me-auto" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnConfirmLink">Insertar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        /* Ajustes básicos del Editor */
        .editor-wrapper {
            background-color: #fff;
            transition: border-color 0.2s;
            min-height: 600px;
            display: flex;
            flex-direction: column;
        }
        .editor-wrapper:focus-within {
            border-color: var(--tblr-primary) !important;
            box-shadow: 0 0 0 0.25rem rgba(32, 107, 196, 0.25);
        }
        .editor-content {
            flex-grow: 1;
            overflow-y: auto;
            outline: none;
            /* Nota: El font-size lo maneja la clase fs-4 en el HTML */
        }
        
        /* Ajustes de Tipografía para que coincida con Article.cshtml */
        /* Eliminamos los tamaños fijos en px/rem y dejamos que Tabler maneje los headers */
        .editor-content h2 { font-weight: 700; color: #1e293b; margin-top: 1.5em; margin-bottom: 0.5em; }
        .editor-content h3 { font-weight: 600; color: #334155; margin-top: 1.2em; margin-bottom: 0.5em; }
        .editor-content p { margin-bottom: 1rem; }
        .editor-content a { color: var(--tblr-primary); text-decoration: underline; cursor: pointer; }
        .editor-content blockquote { border-left: 4px solid var(--tblr-primary); padding-left: 1rem; background: #f8fafc; padding: 1rem; font-style: italic; }

        /* Dark Mode Support */
        body[data-bs-theme="dark"] .editor-wrapper { background-color: #1f2937; border-color: #374151; }
        body[data-bs-theme="dark"] .editor-toolbar { background-color: #111827 !important; border-bottom-color: #374151 !important; }
        body[data-bs-theme="dark"] .editor-content { color: #f3f4f6; }
        body[data-bs-theme="dark"] .editor-content h2, body[data-bs-theme="dark"] .editor-content h3 { color: #ffffff; }
        body[data-bs-theme="dark"] .btn-group.bg-white { background-color: #1f2937 !important; }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var hiddenInput = document.getElementById('hiddenContent');
            var editorArea = document.getElementById('editor-area');
            var savedRange = null; 

            // 1. Cargar contenido inicial
            if(hiddenInput.value && hiddenInput.value.trim() !== "") {
                editorArea.innerHTML = hiddenInput.value;
            }

            // 2. Limpiar placeholder
            editorArea.addEventListener('focus', function() {
                if(this.innerHTML.includes('Escribe tu historia aquí...')) {
                    this.innerHTML = '';
                }
            });

            // 3. Sincronizar
            editorArea.addEventListener('input', function() {
                hiddenInput.value = editorArea.innerHTML;
            });

            // 4. Enviar
            document.getElementById('blogForm').addEventListener('submit', function() {
                hiddenInput.value = editorArea.innerHTML;
            });

            // --- LÓGICA DEL MODAL (Sin cargar JS extra) ---
            var linkModalElement = document.getElementById('modal-insert-link');
            // Usamos el bootstrap global de Tabler
            var bs = window.bootstrap;
            
            if (bs) {
                var linkModal = new bs.Modal(linkModalElement);
                var linkInput = document.getElementById('linkUrlInput');
                var confirmBtn = document.getElementById('btnConfirmLink');

                document.getElementById('btnOpenLinkModal').addEventListener('click', function(e) {
                    e.preventDefault();
                    var selection = window.getSelection();
                    if (selection.rangeCount > 0) {
                        savedRange = selection.getRangeAt(0); 
                    }
                    linkInput.value = '';
                    linkModal.show();
                });

                confirmBtn.addEventListener('click', function() {
                    var url = linkInput.value;
                    if(url) {
                        editorArea.focus();
                        if (savedRange) {
                            var selection = window.getSelection();
                            selection.removeAllRanges();
                            selection.addRange(savedRange);
                        }
                        document.execCommand('createLink', false, url);
                        hiddenInput.value = editorArea.innerHTML;
                    }
                    linkModal.hide();
                });
            }
        });

        function execCmd(command, value = null) {
            document.execCommand(command, false, value);
            document.getElementById('editor-area').focus();
        }
    </script>
}