@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Planes y Precios";
}

<div class="py-6 bg-light">
    <div class="container-xl">
        <div class="text-center mb-6" style="max-width: 700px; margin: 0 auto;">
            <span class="badge bg-green-lt mb-3 text-uppercase">Precios Claros</span>
            <h1 class="display-4 fw-bold mb-3">Invierte en tranquilidad</h1>
            <p class="lead text-muted">
                Elige el plan que se adapte al tamaño de tu facturación. Puedes cambiar o cancelar en cualquier momento sin penalizaciones.
            </p>
            
            <div class="d-flex justify-content-center align-items-center mt-4">
                <span class="fw-bold me-3">Mensual</span>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="billingSwitch">
                </div>
                <span class="text-muted ms-3">Anual <span class="badge bg-green-lt ms-1">-20%</span></span>
            </div>
        </div>
        
        <div class="row row-cards align-items-center justify-content-center">
            
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm hover-shadow transition-all h-100">
                    <div class="card-body p-5 text-center">
                        <div class="text-uppercase text-muted fw-bold mb-2">Emprendedor</div>
                        <div class="display-5 fw-bold text-dark mb-4">Gratis</div>
                        <p class="text-muted mb-4">Ideal para profesionales independientes que emiten pocas facturas.</p>
                        
                        <ul class="list-unstyled space-y-3 text-start mb-5 px-3">
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> <strong>20</strong> Documentos/mes</li>
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> 1 Usuario</li>
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> Reportes Básicos</li>
                            <li class="text-muted opacity-50"><i class="bi bi-dash-circle me-2"></i> Sin IA Predictiva</li>
                            <li class="text-muted opacity-50"><i class="bi bi-dash-circle me-2"></i> Sin Alertas WhatsApp</li>
                        </ul>
                        
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary w-100 btn-lg">
                            Crear cuenta gratis
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card border-primary shadow-lg position-relative transform-hover h-100" style="z-index: 10;">
                    <div class="ribbon ribbon-top bg-primary shadow-sm"><i class="bi bi-star-fill"></i></div>
                    <div class="card-body p-5 text-center">
                        <div class="text-uppercase text-primary fw-bold mb-2">Pymes en Crecimiento</div>
                        <div class="display-4 fw-bold text-dark mb-0">$29</div>
                        <div class="text-muted small mb-4">USD / mes</div>
                        <p class="text-muted mb-4">Para empresas que quieren automatizar y predecir su futuro.</p>
                        
                        <ul class="list-unstyled space-y-3 text-start mb-5 px-3">
                            <li><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Ilimitados</strong> Documentos</li>
                            <li><i class="bi bi-check-circle-fill text-primary me-2"></i> 5 Usuarios</li>
                            <li><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>IA Predictiva Avanzada</strong></li>
                            <li><i class="bi bi-check-circle-fill text-primary me-2"></i> Envío Automático WhatsApp</li>
                            <li><i class="bi bi-check-circle-fill text-primary me-2"></i> Recepción de Gastos (XML)</li>
                        </ul>
                        
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary w-100 btn-lg">
                            Empezar Prueba de 14 días
                        </a>
                        <div class="text-muted small mt-2">No requiere tarjeta de crédito</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm hover-shadow transition-all h-100">
                    <div class="card-body p-5 text-center">
                        <div class="text-uppercase text-muted fw-bold mb-2">Corporativo</div>
                        <div class="display-5 fw-bold text-dark mb-4">Custom</div>
                        <p class="text-muted mb-4">Para grandes volúmenes y necesidades específicas de integración.</p>
                        
                        <ul class="list-unstyled space-y-3 text-start mb-5 px-3">
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> Todo lo de Profesional</li>
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> <strong>Usuarios Ilimitados</strong></li>
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> API Access & Webhooks</li>
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> Soporte Prioritario 24/7</li>
                            <li><i class="bi bi-check-circle-fill text-green me-2"></i> Contrato SLA Garantizado</li>
                        </ul>
                        
                        <a href="#" class="btn btn-outline-primary w-100 btn-lg">
                            Contactar Ventas
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-6 pt-5 border-top justify-content-center text-center">
            <div class="col-md-8">
                <h3 class="mb-4">¿Tienes dudas sobre la facturación?</h3>
                <div class="row text-start g-4">
                    <div class="col-md-6">
                        <h4 class="fw-bold"><i class="bi bi-shield-check text-success me-2"></i> ¿Incluye firma digital?</h4>
                        <p class="text-muted small">Sí, firmamos tus comprobantes en la nube automáticamente. No necesitas comprar tarjeta inteligente ni lectores USB.</p>
                    </div>
                    <div class="col-md-6">
                        <h4 class="fw-bold"><i class="bi bi-arrow-repeat text-blue me-2"></i> ¿Puedo cambiar de plan?</h4>
                        <p class="text-muted small">Cuando quieras. Si tu negocio crece, subes de plan. Si bajas el ritmo, puedes volver al plan gratis el mes siguiente.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .space-y-3 > li {
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
    }
    /* Efectos compartidos con Features para simetría */
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
    .transform-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
</style>