@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Seguridad y Privacidad";
}

<div class="py-6 border-bottom">
    <div class="container-xl text-center">
        <span class="badge bg-teal-lt mb-3 text-uppercase border border-teal-lt px-3 py-2">
            <i class="bi bi-shield-lock-fill me-2"></i> Seguridad Bancaria
        </span>
        <h1 class="display-4 fw-bold mb-3">Tus datos financieros, blindados.</h1>
        <p class="lead text-muted mb-0" style="max-width: 700px; margin: 0 auto;">
            La seguridad no es una característica opcional, es la base de nuestra arquitectura. Utilizamos los mismos estándares de encriptación que los bancos internacionales.
        </p>
    </div>
</div>

<div class="py-6">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all p-4 text-center">
                    <div class="avatar avatar-xl bg-teal-lt rounded-circle mb-4 mx-auto">
                        <i class="bi bi-file-lock2-fill fs-1"></i>
                    </div>
                    <h3 class="mb-3">Encriptación AES-256</h3>
                    <p class="text-muted">Todos tus datos sensibles (contraseñas, llaves criptográficas, montos) se almacenan encriptados en reposo. Nadie, ni siquiera nuestros ingenieros, puede leerlos.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all p-4 text-center">
                    <div class="avatar avatar-xl bg-blue-lt rounded-circle mb-4 mx-auto">
                        <i class="bi bi-cloud-check-fill fs-1"></i>
                    </div>
                    <h3 class="mb-3">Backups Diarios</h3>
                    <p class="text-muted">Realizamos copias de seguridad automáticas de toda la base de datos cada 24 horas y las almacenamos en servidores geográficamente redundantes.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all p-4 text-center">
                    <div class="avatar avatar-xl bg-purple-lt rounded-circle mb-4 mx-auto">
                        <i class="bi bi-eye-slash-fill fs-1"></i>
                    </div>
                    <h3 class="mb-3">Privacidad Total</h3>
                    <p class="text-muted">Tu información financiera es tuya. Nunca vendemos ni compartimos tus datos con terceros para publicidad o mercadeo. Tus datos son sagrados.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="py-6 border-top overflow-hidden">
    <div class="container-xl">
        <div class="row align-items-center">
            
            <div class="col-lg-6 order-lg-2 mb-6 mb-lg-0">
                <div class="reactor-container d-flex justify-content-center align-items-center mx-auto">
                    
                    <div class="orbit-ring ring-outer"></div>
                    
                    <div class="orbit-ring ring-middle"></div>
                    
                    <div class="orbit-ring ring-inner"></div>
                    
                    <div class="reactor-core bg-white shadow-lg rounded-circle d-flex align-items-center justify-content-center">
                        <i class="bi bi-shield-lock-fill text-gradient-primary" style="font-size: 4rem;"></i>
                    </div>

                    <div class="badge-satellite pos-1 bg-white shadow-sm border px-3 py-1 rounded-pill">
                        <i class="bi bi-check-circle-fill text-success me-1"></i> DDoS
                    </div>
                    <div class="badge-satellite pos-2 bg-white shadow-sm border px-3 py-1 rounded-pill">
                        <i class="bi bi-lock-fill text-warning me-1"></i> SSL
                    </div>
                    <div class="badge-satellite pos-3 bg-white shadow-sm border px-3 py-1 rounded-pill">
                        <i class="bi bi-hdd-fill text-azure me-1"></i> AWS
                    </div>

                </div>
            </div>

            <div class="col-lg-6 order-lg-1">
                <h2 class="display-5 fw-bold mb-4">Defensa en Profundidad</h2>
                <p class="text-muted mb-4 fs-3">
                    No confiamos en una sola cerradura. Nuestra arquitectura de seguridad opera en múltiples capas simultáneas para garantizar la integridad de tu negocio.
                </p>
                
                <div class="vstack gap-3">
                    <div class="d-flex p-3 rounded border shadow-sm transition-all hover-shadow">
                        <div class="me-3">
                            <span class="avatar bg-green-lt"><i class="bi bi-shield-check"></i></span>
                        </div>
                        <div>
                            <h4 class="m-0 fw-bold">Capa 1: Perímetro</h4>
                            <p class="text-muted small m-0">Firewall de Aplicaciones Web (WAF) que bloquea ataques antes de que lleguen.</p>
                        </div>
                    </div>

                    <div class="d-flex p-3 rounded border shadow-sm transition-all hover-shadow">
                        <div class="me-3">
                            <span class="avatar bg-blue-lt"><i class="bi bi-lock"></i></span>
                        </div>
                        <div>
                            <h4 class="m-0 fw-bold">Capa 2: Tránsito</h4>
                            <p class="text-muted small m-0">Certificados de grado bancario. Nadie puede interceptar tus facturas.</p>
                        </div>
                    </div>

                    <div class="d-flex p-3 rounded border shadow-sm transition-all hover-shadow">
                        <div class="me-3">
                            <span class="avatar bg-purple-lt"><i class="bi bi-database"></i></span>
                        </div>
                        <div>
                            <h4 class="m-0 fw-bold">Capa 3: Datos</h4>
                            <p class="text-muted small m-0">Tus datos viven en una base de datos aislada lógicamente de otros clientes.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="cta-gradient text-white text-center full-bleed py-6 position-relative overflow-hidden">
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="container-xl position-relative z-index-1">
        <h2 class="mb-3 display-6 fw-bold">¿Tienes preguntas técnicas?</h2>
        <p class="text-white-75 mb-4">Nuestro oficial de seguridad puede responder tus dudas sobre cumplimiento.</p>
        <a asp-action="Contact" class="btn btn-outline-light px-4 border-2 fw-bold hover-scale">Contactar Seguridad</a>
    </div>
</div>

<style>
    /* Estilos Generales */
    .hover-shadow:hover { transform: translateY(-3px); box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important; }
    .transition-all { transition: all 0.3s ease; }
    .cta-gradient { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
    .hover-scale:hover { transform: scale(1.05); transition: 0.2s; }
    .text-gradient-primary {
        background: linear-gradient(135deg, var(--tblr-primary) 0%, #a55eea 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* --- ANIMACIÓN: REACTOR DE SEGURIDAD --- */
    
    .reactor-container {
        width: 400px;
        height: 400px;
        position: relative;
    }

    /* Núcleo Central */
    .reactor-core {
        width: 140px;
        height: 140px;
        z-index: 10;
        position: relative;
        border: 1px solid rgba(0,0,0,0.05);
    }

    /* Anillos Orbitales */
    .orbit-ring {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        border: 1px solid transparent;
    }

    /* Anillo 1: Grande, lento, discontinuo */
    .ring-outer {
        width: 380px;
        height: 380px;
        border-top: 2px solid var(--tblr-primary);
        border-bottom: 2px solid var(--tblr-primary);
        opacity: 0.3;
        animation: spin-right 12s linear infinite;
    }

    /* Anillo 2: Medio, velocidad media, color secundario */
    .ring-middle {
        width: 280px;
        height: 280px;
        border-left: 2px solid var(--tblr-green);
        border-right: 2px solid var(--tblr-green);
        opacity: 0.5;
        animation: spin-left 8s linear infinite;
    }

    /* Anillo 3: Pequeño, rápido, brillante */
    .ring-inner {
        width: 180px;
        height: 180px;
        border-top: 4px solid var(--tblr-purple);
        opacity: 0.8;
        animation: spin-right 4s linear infinite;
    }

    /* Etiquetas Satélite (Flotando estáticas sobre los anillos) */
    .badge-satellite {
        position: absolute;
        z-index: 5;
        font-size: 0.8rem;
        font-weight: bold;
        color: #555;
    }
    .pos-1 { top: 15%; right: 15%; animation: float-1 4s ease-in-out infinite; }
    .pos-2 { bottom: 20%; left: 10%; animation: float-2 5s ease-in-out infinite; }
    .pos-3 { top: 10%; left: 30%; animation: float-3 4.5s ease-in-out infinite; }

    /* Keyframes de Rotación (Escapados con @@ para Razor) */
    @@keyframes spin-right {
        100% { transform: translate(-50%, -50%) rotate(360deg); }
    }
    
    @@keyframes spin-left {
        100% { transform: translate(-50%, -50%) rotate(-360deg); }
    }

    /* Keyframes de Flotación suave para las etiquetas */
    @@keyframes float-1 { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    @@keyframes float-2 { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(8px); } }
    @@keyframes float-3 { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }

</style>