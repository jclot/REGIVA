<div class="cta-gradient text-white text-center full-bleed position-relative overflow-hidden">
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10" 
         style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;">
    </div>
    
    <div class="container-xl py-6 position-relative z-index-1">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <span class="badge bg-white text-primary text-uppercase fw-bold mb-3 px-3 py-2 shadow-sm">
                    Soporte Humano
                </span>
                
                <h2 class="display-4 fw-bold mb-3">¿No encontraste lo que buscabas?</h2>
                <p class="lead mb-5 text-white-75 fs-3" style="max-width: 600px; margin: 0 auto;">
                    Nuestro equipo de soporte en Costa Rica está listo para ayudarte a resolver cualquier duda en minutos.
                </p>
                
                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 align-items-center">
                    <a href="#" class="btn btn-white btn-lg px-5 text-primary fw-bold shadow hover-scale">
                        <i class="bi bi-whatsapp me-2"></i> Chat en Vivo
                    </a>
                    <a href="mailto:soporte@cfoautonomo.cr" class="text-white text-decoration-none fw-medium hover-underline mt-2 mt-sm-0">
                        <i class="bi bi-envelope me-1"></i> Enviar Correo Electrónico
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos compartidos del Landing para consistencia */
    .ls-2 { letter-spacing: 2px; }
    
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
    
    /* CTA Gradient Background */
    .cta-gradient {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }
    
    /* Botones CTA */
    .hover-scale:hover { transform: scale(1.05); transition: 0.2s; }
    .hover-underline:hover { text-decoration: underline !important; }
    
    /* Input Search Size */
    .form-control-lg { font-size: 1.1rem; }
</style>