@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Centro de Ayuda";
}

<div class="py-6 bg-light">
    <div class="container-xl">
        <div class="text-center mb-6" style="max-width: 700px; margin: 0 auto;">
