@using REGIVA_CR.AB.ModelosParaUI.General
@model List<HelpArticleDto>

@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Centro de Ayuda";
    string searchQuery = ViewData["SearchQuery"] as string ?? "";
}

<div class="py-6">
    <div class="container-xl">
        <div class="text-center mb-6" style="max-width: 700px; margin: 0 auto;">
            <span class="badge bg-purple-lt mb-3 text-uppercase">Centro de Ayuda</span>
            <h1 class="display-4 fw-bold mb-3">¿Cómo podemos ayudarte?</h1>
            <p class="lead text-muted mb-4">
                Encuentra guías sobre Hacienda, facturación y configuración de tu cuenta.
            </p>
            
            <form asp-action="Docs" method="get" class="mt-5 mx-auto" style="max-width: 600px;">
                <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border">
                    <span class="input-group-text border-0 bg-transparent ps-4 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    
                    <input type="text" name="q" value="@searchQuery" 
                           class="form-control border-0 shadow-none ps-2" 
                           placeholder="Buscar 'Error de Hacienda', 'Crear Cliente'..." 
                           autocomplete="off">
                    
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <a asp-action="Docs" class="btn bg-transparent border-0 text-muted d-flex align-items-center px-3" title="Borrar búsqueda">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                    
                    <button type="submit" class="btn btn-primary px-4 fw-bold border-start">
                        Buscar
                    </button>
                </div>
            </form>
            </div>

        <div class="mb-5">
            <div class="d-flex align-items-center justify-content-center mb-4">
                <span class="avatar bg-blue-lt rounded me-2"><i class="bi bi-folder2-open"></i></span>
                <h3 class="m-0 text-uppercase ls-2 text-muted small fw-bold">Explorar por Categoría</h3>
            </div>

            <div class="row row-cards">
                <div class="col-md-4">
                    <a href="@Url.Action("Docs", new { q = "Primeros Pasos" })" class="card h-100 border-0 shadow-sm hover-shadow transition-all text-decoration-none">
                        <div class="card-body text-center p-4">
                            <div class="avatar avatar-lg bg-blue-lt rounded-circle mb-3"><i class="bi bi-rocket-takeoff-fill fs-2"></i></div>
                            <h3 class="card-title mb-2">Primeros Pasos</h3>
                            <p class="text-muted small">Configuración de llave criptográfica y perfil.</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="@Url.Action("Docs", new { q = "Facturación" })" class="card h-100 border-0 shadow-sm hover-shadow transition-all text-decoration-none">
                        <div class="card-body text-center p-4">
                            <div class="avatar avatar-lg bg-green-lt rounded-circle mb-3"><i class="bi bi-receipt-cutoff fs-2"></i></div>
                            <h3 class="card-title mb-2">Facturación</h3>
                            <p class="text-muted small">Emitir facturas, notas de crédito y correos.</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="@Url.Action("Docs", new { q = "Errores" })" class="card h-100 border-0 shadow-sm hover-shadow transition-all text-decoration-none">
                        <div class="card-body text-center p-4">
                            <div class="avatar avatar-lg bg-red-lt rounded-circle mb-3"><i class="bi bi-exclamation-triangle-fill fs-2"></i></div>
                            <h3 class="card-title mb-2">Solución de Errores</h3>
                            <p class="text-muted small">Qué hacer si Hacienda rechaza un documento.</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="py-6 border-top">
    <div class="container-xl">
        <div class="text-center mb-5">
            @if (string.IsNullOrEmpty(searchQuery))
            {
                <h2 class="display-6 fw-bold">Artículos más consultados</h2>
            }
            else
            {
                <h2 class="display-6 fw-bold">Resultados para: "@searchQuery"</h2>
                <p class="text-muted">Encontramos @Model.Count artículos.</p>
            }
        </div>
        
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="list-group list-group-flush">
                        
                        @if (Model.Count == 0)
                        {
                            <div class="text-center p-5">
                                <i class="bi bi-emoji-frown fs-1 text-muted"></i>
                                <p class="mt-3 text-muted">No encontramos artículos con esa búsqueda.</p>
                                <a asp-action="Docs" class="btn btn-outline-primary btn-sm">Ver todos</a>
                            </div>
                        }

                        @foreach (var article in Model)
                        {
                            <a asp-action="Article" asp-route-id="@article.Id" class="list-group-item list-group-item-action p-4 d-flex align-items-center">
                                <div class="me-3">
                                    <span class="avatar bg-blue-lt rounded"><i class="@(article.IconClass ?? "bi-file-text") fs-4"></i></span>
                                </div>
                                <div class="flex-fill">
                                    <div class="fw-bold">@article.Title</div>
                                    <div class="text-muted small">@article.Category • @article.Summary</div>
                                </div>
                                <div class="text-muted"><i class="bi bi-chevron-right"></i></div>
                            </a>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover { transform: translateY(-5px); box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important; }
    .transition-all { transition: all 0.3s ease; }
    .input-group:focus-within {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        border-color: var(--tblr-primary) !important;
        transition: box-shadow 0.2s ease;
    }
</style>