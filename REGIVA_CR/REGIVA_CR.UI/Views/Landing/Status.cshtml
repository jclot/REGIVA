@using REGIVA_CR.AB.ModelosParaUI.General
@model SubscriberDto 
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Estado del Sistema";
}

<div class="py-6  border-bottom">
    <div class="container-xl text-center">
        <div class="d-inline-flex align-items-center px-5 py-3 rounded-pill shadow-sm mb-4 border border-success-lt">
            <span class="position-relative d-flex me-3">
                <span class="status-dot status-dot-animated bg-success" style="width: 16px; height: 16px;"></span>
            </span>
            <span class="fw-bold text-success fs-3">Todos los sistemas operativos</span>
        </div>
        
        <h1 class="fw-bold mb-2">Estado de la Plataforma</h1>
        <p class="text-muted">Última actualización: @DateTime.Now.ToString("dd MMM yyyy, HH:mm")</p>
    </div>
</div>

<div class="py-6 ">
    <div class="container-xl" style="max-width: 800px;">
        
        <div class="card mb-5 border-0 shadow-sm overflow-hidden">
            <div class="card-header border-bottom">
                <h3 class="card-title m-0 fw-bold"><i class="bi bi-cpu me-2"></i> Plataforma CFO Autónomo</h3>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item d-flex align-items-center justify-content-between py-3 px-4">
                    <div class="d-flex align-items-center">
                        <span class="bg-blue-lt avatar rounded me-3"><i class="bi bi-globe"></i></span>
                        <div>
                            <span class="fw-bold d-block ">Sitio Web & Dashboard</span>
                            <small class="text-muted">Acceso clientes</small>
                        </div>
                    </div>
                    <span class="badge bg-green-lt text-uppercase px-3">Operativo</span>
                </div>
                <div class="list-group-item d-flex align-items-center justify-content-between py-3 px-4">
                    <div class="d-flex align-items-center">
                        <span class="bg-purple-lt avatar rounded me-3"><i class="bi bi-robot"></i></span>
                        <div>
                            <span class="fw-bold d-block">Motor de IA Predictiva</span>
                            <small class="text-muted">Procesamiento de datos</small>
                        </div>
                    </div>
                    <span class="badge bg-green-lt text-uppercase px-3">Operativo</span>
                </div>
                <div class="list-group-item d-flex align-items-center justify-content-between py-3 px-4">
                    <div class="d-flex align-items-center">
                        <span class="bg-orange-lt avatar rounded me-3"><i class="bi bi-database"></i></span>
                        <div>
                            <span class="fw-bold d-block">Base de Datos</span>
                            <small class="text-muted">Latencia y disponibilidad</small>
                        </div>
                    </div>
                    <span class="badge bg-green-lt text-uppercase px-3">Operativo</span>
                </div>
            </div>
        </div>

        <div class="card mb-5 border-0 shadow-sm overflow-hidden">
            <div class="card-header border-bottom">
                <h3 class="card-title m-0 fw-bold"><i class="bi bi-diagram-3 me-2"></i> Integraciones Externas</h3>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item d-flex align-items-center justify-content-between py-3 px-4">
                    <div class="d-flex align-items-center">
                        <span class="bg-yellow-lt avatar rounded me-3"><i class="bi bi-building"></i></span>
                        <div>
                            <span class="fw-bold d-block">Ministerio de Hacienda (ATV)</span>
                            <small class="text-muted">Recepción de XMLs (Responsabilidad de la DGT)</small>
                        </div>
                    </div>
                    <span class="badge bg-green-lt text-uppercase px-3">Operativo</span>
                </div>
                <div class="list-group-item d-flex align-items-center justify-content-between py-3 px-4">
                    <div class="d-flex align-items-center">
                        <span class="bg-green-lt avatar rounded me-3"><i class="bi bi-whatsapp"></i></span>
                        <div>
                            <span class="fw-bold d-block">WhatsApp API (Meta)</span>
                            <small class="text-muted">Envío de notificaciones</small>
                        </div>
                    </div>
                    <span class="badge bg-green-lt text-uppercase px-3">Operativo</span>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <h4 class="mb-3 text-muted">Historial de Incidentes</h4>
            <div class="card card-body border-0 shadow-inner">
                <div class="text-muted small">
                    <i class="bi bi-check-circle-fill text-success me-1"></i> No se han reportado incidentes en los últimos 30 días.
                </div>
            </div>
        </div>

    </div>
</div>

<div class="bg-dark text-white text-center py-5 full-bleed">
    <div class="container-xl">
        <div class="d-flex flex-column flex-md-row justify-content-center align-items-center gap-3">
            <span class="fw-medium"><i class="bi bi-envelope me-2"></i> ¿Quieres recibir alertas de caídas de Hacienda o Novedades?</span>
            
            <button type="button" class="btn btn-primary btn-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#modal-subscribe">
                Suscribirse a Alertas
            </button>
        </div>
    </div>
</div>

<div class="modal modal-blur fade" id="modal-subscribe" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Suscripción a Alertas REGIVA</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-action="Subscribe" method="post">
                @Html.AntiForgeryToken()
                
                <div class="modal-body">
                    
                    <div class="mb-3">
                        <label class="form-label required">Nombre Completo</label>
                        <input asp-for="Name" type="text" class="form-control" placeholder="Tu nombre" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label required">Correo Electrónico</label>
                        <div class="input-group input-group-flat">
                            <span class="input-group-text">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Email" type="email" class="form-control ps-2" placeholder="ejemplo@correo.com" required />
                        </div>
                        <div class="form-text">Nunca compartiremos tu correo con terceros.</div>
                    </div>

                    <label class="form-label">¿Qué tipo de alertas deseas recibir?</label>
                    <div class="form-selectgroup-boxes row mb-3">
                        
                        <div class="col-md-6">
                            <label class="form-selectgroup-item">
                                <input asp-for="SystemAlerts" type="checkbox" class="form-selectgroup-input" checked />
                                <span class="form-selectgroup-label d-flex align-items-center p-3">
                                    <span class="me-3">
                                        <span class="form-selectgroup-check"></span>
                                    </span>
                                    <span class="form-selectgroup-label-content">
                                        <span class="form-selectgroup-title strong mb-1">
                                            <i class="bi bi-exclamation-triangle me-1 text-orange"></i> Estado del Sistema
                                        </span>
                                        <span class="d-block text-muted">
                                            Recibe avisos inmediatos sobre caídas de Hacienda (ATV) o mantenimiento de REGIVA.
                                        </span>
                                    </span>
                                </span>
                            </label>
                        </div>

                        <div class="col-md-6">
                            <label class="form-selectgroup-item">
                                <input asp-for="Newsletter" type="checkbox" class="form-selectgroup-input" />
                                <span class="form-selectgroup-label d-flex align-items-center p-3">
                                    <span class="me-3">
                                        <span class="form-selectgroup-check"></span>
                                    </span>
                                    <span class="form-selectgroup-label-content">
                                        <span class="form-selectgroup-title strong mb-1">
                                            <i class="bi bi-megaphone me-1 text-blue"></i> Novedades y Anuncios
                                        </span>
                                        <span class="d-block text-muted">
                                            Entérate de nuevas funcionalidades, mejoras fiscales y noticias importantes.
                                        </span>
                                    </span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <a href="#" class="btn btn-link link-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary ms-auto">
                        <i class="bi bi-bell-fill me-2"></i> Suscribirme ahora
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>