<style>
    /* Gradient Text */
    .text-gradient {
        background: linear-gradient(135deg, var(--tblr-primary) 0%, #2fb344 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* CTA Gradient Background */
    .cta-gradient {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); /* Azul oscuro moderno */
    }

    /* Botones CTA */
    .btn-pill { border-radius: 50rem; }
    .hover-lift { transition: transform 0.2s; }
    .hover-lift:hover { transform: translateY(-3px); }
    .hover-scale:hover { transform: scale(1.05); transition: 0.2s; }
    .hover-underline:hover { text-decoration: underline !important; }

    /* Logo Cloud */
    .tracking-wide { letter-spacing: 0.1em; }
    .logo-cloud .logo-item {
        color: #6c757d; opacity: 0.5; transition: all 0.3s ease; filter: grayscale(100%);
        display: flex; align-items: center; justify-content: center; cursor: default;
    }
    .logo-cloud .logo-item:hover { color: var(--tblr-primary); opacity: 1; filter: grayscale(0%); transform: scale(1.05); }

    /* FAQ */
    .accordion-custom .accordion-button { background-color: white; }
    .accordion-custom .accordion-button:not(.collapsed) { color: var(--tblr-dark); background-color: white; box-shadow: none; }
    .accordion-custom .accordion-button:focus { box-shadow: none; border-color: rgba(0,0,0,.125); }
    .accordion-custom .accordion-button::after { background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23206bc4'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e"); transform: scale(.8); }

    /* General */
    .hover-shadow:hover { transform: translateY(-5px); box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important; }
    .transition-all { transition: all 0.3s ease; }
    .tilt-effect:hover { transform: rotate(0deg) !important; }
    .space-y-2 > li { margin-bottom: 0.75rem; }
</style>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        var options = {
            chart: { type: 'area', height: 220, fontFamily: 'Inter, sans-serif', toolbar: { show: false }, animations: { enabled: true } },
            dataLabels: { enabled: false },
            stroke: { width: 3, curve: 'smooth', dashArray: [0, 5] },
            series: [{ name: 'Flujo Real', data: [120, 145, 130, 180, 160, 210, 190, null, null, null, null, null] }, { name: 'Predicción IA', data: [null, null, null, null, null, null, 190, 220, 240, 210, 260, 300] }],
            fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05, stops: [0, 90, 100] } },
            colors: ['#206bc4', '#2fb344'],
            xaxis: { categories: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'], labels: { style: { colors: '#6c757d', fontSize: '11px' } }, axisBorder: { show: false }, axisTicks: { show: false } },
            yaxis: { show: false },
            grid: { borderColor: '#f2f3f5', strokeDashArray: 4, yaxis: { lines: { show: true } } },
            tooltip: { theme: 'light', y: { formatter: function (val) { return "₡" + val + "K" } } },
            legend: { position: 'top', horizontalAlign: 'right' }
        };
        var chart = new ApexCharts(document.querySelector("#chart-predictive-ia"), options);
        chart.render();
    });
</script>