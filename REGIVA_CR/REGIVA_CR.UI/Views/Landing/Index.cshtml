        <div class="position-absolute top-0 start-50 translate-middle rounded-circle opacity-10" style="width: 600px; height: 600px; background: radial-gradient(circle, var(--tblr-primary) 0%, transparent 70%); filter: blur(80px);"></div>
    </div>

    <div class="container-xl py-6">
