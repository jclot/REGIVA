@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Características";
}


<div class="py-5">
    <div class="container-xl">
        <div class="text-center mb-5">
            <h1 class="mb-2">Objetivos claros</h1>
            <p class="text-muted">Todo automaticamente desde tu casa.</p>
        </div>
        <div class="row row-cards">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="bg-blue text-white avatar me-3"><i class="bi bi-receipt"></i></span>
                            <h3 class="m-0">Facturación Electrónica v4.4</h3>
                        </div>
                        <p class="text-muted">Cumplimiento total con la normativa vigente de Costa Rica. Generación de XML, envío automático a Hacienda y recepción de respuesta en segundos.</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="bg-purple text-white avatar me-3"><i class="bi bi-cpu"></i></span>
                            <h3 class="m-0">IA Predictiva</h3>
                        </div>
                        <p class="text-muted">Algoritmos que analizan tu historial de facturación para proyectar tus flujos de caja a 30, 60 y 90 días con un 85% de precisión.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="bg-green text-white avatar me-3"><i class="bi bi-whatsapp"></i></span>
                            <h3 class="m-0">Alertas WhatsApp</h3>
                        </div>
                        <p class="text-muted">Notificaciones automáticas a tus clientes cuando una factura vence, y alertas para ti cuando Hacienda rechaza un documento.</p>
                    </div>
                </div>
            </div>

             <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <span class="bg-yellow text-white avatar me-3"><i class="bi bi-bank"></i></span>
                            <h3 class="m-0">Scoring Crediticio</h3>
                        </div>
                        <p class="text-muted">Analiza el comportamiento de pago de tus clientes antes de ofrecer crédito. Un semáforo de riesgo simple integrado en tu CRM.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>