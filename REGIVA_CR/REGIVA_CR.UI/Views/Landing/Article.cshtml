@using REGIVA_CR.AB.ModelosParaUI.General
@model HelpArticleDto

@{
    Layout = "_PublicLayout";
    ViewData["Title"] = Model.Title;
}

<div class="py-5 border-bottom">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="mb-4">
                    <a asp-controller="Landing" asp-action="Docs" class="btn-back-home d-inline-flex align-items-center text-decoration-none">
                        <i class="bi bi-arrow-left me-2 fs-3"></i> 
                        <span>Volver al Centro de Ayuda</span>
                    </a>
                </div>
                <div class="d-flex align-items-center flex-wrap mb-3">
    
    <span class="badge bg-blue-lt me-3">@Model.Category</span>

    <div class="d-flex align-items-center me-3">
        <span class="avatar avatar-xs rounded-circle me-2" 
              style="background-image: url('https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Author)&background=206bc4&color=fff&size=64&bold=true')">
        </span>
        
        <div class="d-flex align-items-center">
            <span class="fw-bold small">@Model.Author</span>

            @if (Model.Author.Equals("REGIVA", StringComparison.OrdinalIgnoreCase))
            {
                <i class="bi bi-patch-check-fill text-blue ms-1" 
                   style="font-size: 0.9rem;" 
                   title="Cuenta Verificada Oficial"
                   data-bs-toggle="tooltip"></i>
            }
        </div>
    </div>

    <span class="text-muted small me-3">&bull;</span>

    <span class="text-muted small">Actualizado: @Model.LastUpdated.ToString("dd MMM yyyy")</span>

</div>
                <h1 class="fw-bold mb-0">@Model.Title</h1>
            </div>
        </div>
    </div>
</div>

<div class="py-6">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-5 fs-4" style="line-height: 1.8;">
                        @Html.Raw(Model.ContentHtml)
                    </div>
                    <div class="card-footer p-4 text-center">
                        <p class="mb-3 fw-bold">¿Te fue útil este artículo?</p>
                        <button class="btn btn-outline-success me-2"><i class="bi bi-hand-thumbs-up me-2"></i> Sí, gracias</button>
                        <a asp-action="Contact" class="btn btn-outline-secondary"><i class="bi bi-chat-text me-2"></i> No, necesito ayuda</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-back-home {
        transition: all 0.3s ease;
        font-weight: 500;
        color: #6c757d;
    }
    .btn-back-home:hover {
        color: var(--tblr-primary);
        text-decoration: none;
        transform: translateX(-5px);
    }
</style>