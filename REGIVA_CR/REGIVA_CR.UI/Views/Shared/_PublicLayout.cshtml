<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - El CFO Autónomo</title>
    <link rel="stylesheet" href="~/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <style>
        :root { --tblr-font-sans-serif: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
        body { font-feature-settings: "cv03", "cv04", "cv11"; }
        /* Corrección visual para asegurar que no haya scroll horizontal accidental */
        body { overflow-x: hidden; }

        .full-bleed { margin-left: calc(-1 * var(--tblr-page-padding)); margin-right: calc(-1 * var(--tblr-page-padding));
}

    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <header class="navbar navbar-expand-md navbar-light d-print-none sticky-top border-bottom">
        <div class="container-xl">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
                <a asp-controller="Landing" asp-action="Index">
                    <i class="bi bi-graph-up-arrow text-primary me-2"></i> CFO Autónomo CR
                </a>
            </h1>
            <div class="navbar-nav flex-row order-md-last">
                <div class="nav-item d-none d-md-flex me-3">
                    <div class="btn-list">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Iniciar Sesión</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Empezar Gratis</a>
                    </div>
                </div>
            </div>
            <div class="collapse navbar-collapse" id="navbar-menu">
                <div class="d-flex flex-column flex-md-row flex-fill align-items-stretch align-items-md-center">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Features">
                                <span class="nav-link-title">Características</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Pricing">
                                <span class="nav-link-title">Precios</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Docs">
                                <span class="nav-link-title">Documentación</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-fill">
        @RenderBody()
    </main>
    
    <footer class="footer footer-transparent d-print-none py-5 bg-light border-top mt-auto">
        <div class="container-xl">
            <div class="row text-center align-items-center flex-row-reverse">
                <div class="col-lg-auto ms-lg-auto">
                    <ul class="list-inline list-inline-dots mb-0">
                        <li class="list-inline-item"><a asp-action="Docs" class="link-secondary">Ayuda</a></li>
                        <li class="list-inline-item"><a asp-action="Terms" class="link-secondary">Términos</a></li>
                    </ul>
                </div>
                <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                    <ul class="list-inline list-inline-dots mb-0">
                        <li class="list-inline-item">
                            Copyright &copy; @DateTime.Now.Year CFO Autónomo CR. Hecho con <i class="bi bi-heart text-danger"></i> en Costa Rica.
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/tabler.min.js" asp-append-version="true"></script>
</body>
</html>