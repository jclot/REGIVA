<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - El CFO Autónomo</title>
    <link rel="stylesheet" href="~/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    
    <style>
        :root { --tblr-font-sans-serif: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
        
        /* Reset básico */
        html, body {
            width: 100%;
            overflow-x: hidden;
            font-feature-settings: "cv03", "cv04", "cv11";
        }

        /* Navbar Glassmorphism */
        .navbar-custom {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }
        .navbar-scrolled {
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            padding-top: 0.5rem !important;
            padding-bottom: 0.5rem !important;
        }

        /* --- MENÚ & BOTONES --- */
        .nav-link { 
            font-weight: 500; 
            color: #1d273b; 
            transition: color 0.2s ease-in-out; 
        }
        .nav-link:hover, .nav-link:focus {
            color: var(--tblr-primary) !important; 
        }

        /* Botón Iniciar Sesión Personalizado */
        .btn-nav-login {
            color: #64748b; /* Gris pizarra elegante */
            background: transparent;
            border: 1px solid transparent;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-nav-login:hover {
            color: var(--tblr-primary); /* Texto Azul */
            background-color: rgba(32, 107, 196, 0.08); /* Fondo Azul muy sutil */
            transform: translateY(-1px);
        }

        /* Botón CTA Principal (Register) */
        .btn-navbar-anim {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .btn-navbar-anim:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(30, 41, 59, 0.25); /* Sombra más pronunciada */
        }
        
        /* --- FOOTER LINKS & SOCIAL --- */
        .footer-link-hover:hover {
            color: var(--tblr-primary) !important;
            text-decoration: underline;
            transition: color 0.2s;
        }

        /* Iconos Sociales Atractivos */
        .social-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 50%;
            background: rgba(255,255,255,0.06); /* Círculo sutil */
            color: #9ca3af; /* Gris claro */
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none !important;
            margin-right: 0.75rem;
        }
        
        /* Efecto Hover Genérico */
        .social-link:hover {
            transform: translateY(-5px) scale(1.1);
            color: white; /* Icono se vuelve blanco puro */
        }

        /* Colores Específicos de Marca al Hover + Glow Effect */
        .social-fb:hover { 
            background-color: #1877F2; 
            box-shadow: 0 5px 15px rgba(24, 119, 242, 0.4); 
        }
        .social-ig:hover { 
            background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); 
            box-shadow: 0 5px 15px rgba(220, 39, 67, 0.4); 
        }
        .social-li:hover { 
            background-color: #0A66C2; 
            box-shadow: 0 5px 15px rgba(10, 102, 194, 0.4); 
        }
        .social-wa:hover { 
            background-color: #25D366; 
            box-shadow: 0 5px 15px rgba(37, 211, 102, 0.4); 
        }

    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <header class="navbar navbar-expand-md navbar-custom d-print-none sticky-top py-3 w-100">
        <div class="container-xl">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <a asp-controller="Landing" asp-action="Index" class="navbar-brand d-none-navbar-horizontal pe-0 pe-md-3">
                <span class="avatar bg-primary text-white rounded-2 me-2" style="width: 32px; height: 32px; min-width: 32px;">
                    <i class="bi bi-graph-up-arrow fs-5"></i>
                </span>
                <span class="fw-bold tracking-tight text-dark" style="letter-spacing: -0.5px; font-size: 1.25rem;">CFO Autónomo</span>
            </a>

            <div class="navbar-nav flex-row order-md-last">
                <div class="nav-item d-none d-md-flex me-2">
                    <div class="btn-list">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-nav-login">
                            Iniciar Sesión
                        </a>
                        <a asp-controller="Account" asp-action="Register" asp-route-restart="true" class="btn btn-dark px-4 rounded-2 btn-navbar-anim">
                            Empezar Gratis
                        </a>
                    </div>
                </div>
            </div>

            <div class="collapse navbar-collapse" id="navbar-menu">
                <div class="d-flex flex-column flex-md-row flex-fill align-items-stretch align-items-md-center">
                    <ul class="navbar-nav ms-md-auto me-md-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Features">Características</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Pricing">Precios</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Docs">Recursos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Contact">Contacto</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Security">Seguridad</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Landing" asp-action="Status">Estatus</a>
                        </li>
                    </ul>
                    <div class="d-md-none mt-3 pb-2">
                        <a asp-controller="Account" asp-action="Login" class="btn w-100 mb-2">Iniciar Sesión</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary w-100">Crear Cuenta</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-fill w-100">
        @RenderBody()
    </main>
    
    <footer class="d-print-none bg-dark text-light pt-6 pb-4 w-100 mt-auto">
        <div class="container-xl">
            <div class="row g-4">
                
                <div class="col-12 col-lg-4 mb-4 mb-lg-0">
                    <a asp-controller="Landing" asp-action="Index" class="d-flex align-items-center text-white text-decoration-none mb-3">
                        <i class="bi bi-graph-up-arrow text-primary fs-2 me-2"></i>
                        <span class="h2 fw-bold m-0">CFO Autónomo</span>
                    </a>
                    <p class="text-secondary pe-lg-4">
                        La plataforma financiera impulsada por IA para PYMES costarricenses. Automatiza, predice y crece con tranquilidad.
                    </p>
                    
                    <div class="mt-4 d-flex">
                        <a href="#" class="social-link social-fb" title="Facebook"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="social-link social-ig" title="Instagram"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" class="social-link social-li" title="LinkedIn"><i class="bi bi-linkedin fs-5"></i></a>
                        <a href="#" class="social-link social-wa" title="WhatsApp"><i class="bi bi-whatsapp fs-5"></i></a>
                    </div>
                </div>

                <div class="col-6 col-lg-2">
                    <h4 class="text-white mb-3">Producto</h4>
                    <ul class="list-unstyled space-y-2">
                        <li><a asp-controller="Landing" asp-action="Features" class="text-secondary text-decoration-none footer-link-hover">Características</a></li>
                        <li><a asp-controller="Landing" asp-action="Pricing" class="text-secondary text-decoration-none footer-link-hover">Planes</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Facturación CR</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">IA Predictiva</a></li>
                    </ul>
                </div>

                <div class="col-6 col-lg-2">
                    <h4 class="text-white mb-3">Recursos</h4>
                    <ul class="list-unstyled space-y-2">
                        <li><a asp-controller="Landing" asp-action="Docs" class="text-secondary text-decoration-none footer-link-hover">Documentación</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Blog Financiero</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Guía Hacienda</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Estado del Sistema</a></li>
                    </ul>
                </div>

                <div class="col-6 col-lg-2">
                    <h4 class="text-white mb-3">Legal</h4>
                    <ul class="list-unstyled space-y-2">
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Términos de Uso</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Privacidad</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link-hover">Seguridad</a></li>
                    </ul>
                </div>
            </div>

            <div class="border-top border-secondary mt-5 pt-4 text-center text-secondary small">
                <div class="row align-items-center">
                    <div class="col-12 col-md-6 text-md-start">
                        Copyright &copy; @DateTime.Now.Year <strong>CFO Autónomo CR</strong>. Todos los derechos reservados.
                    </div>
                    <div class="col-12 col-md-6 text-md-end mt-2 mt-md-0">
                        Hecho con <i class="bi bi-heart-fill text-danger mx-1"></i> en San José, Costa Rica.
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/tabler.min.js" asp-append-version="true"></script>
    <script>
        window.addEventListener('scroll', function() {
            var navbar = document.querySelector('.navbar');
            if (window.scrollY > 10) {
                navbar.classList.add('navbar-scrolled');
            } else {
                navbar.classList.remove('navbar-scrolled');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>