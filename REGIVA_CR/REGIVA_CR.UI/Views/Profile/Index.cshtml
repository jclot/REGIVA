@using REGIVA_CR.AB.ModelosParaUI.Auth
@model UserProfileDto

@{
    Layout = "_Layout";
    ViewData["Title"] = "Perfil de Usuario";
}

<div class="page-header">
    <div class="container-xl">
        <h2 class="page-title">Mi Perfil</h2>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            
            <div class="col-lg-4">
                <div class="card mb-3">
                    <div class="card-body text-center">
                        <span class="avatar avatar-xl mb-3 rounded-circle shadow-sm" 
                              style="background-image: url('https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName)&background=206bc4&color=fff&size=128&bold=true')">
                        </span>
                        
                        <h3 class="m-0 mb-1 fw-bold">@Model.FullName</h3>
                        <div class="text-muted text-truncate">@Model.Email</div>
                        
                        <div class="mt-3">
                            <span class="badge bg-blue-lt text-uppercase">@Model.Role</span>
                        </div>
                    </div>
                    
                    <div class="card-body border-top">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center ps-0 pe-0">
                                <span class="text-muted"><i class="bi bi-telephone me-2"></i>Teléfono</span>
                                <span class="fw-medium">@Model.Phone</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center ps-0 pe-0">
                                <span class="text-muted"><i class="bi bi-calendar3 me-2"></i>Miembro desde</span>
                                <span class="fw-medium">@Model.MemberSince.ToString("MMM yyyy")</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer">
                        <a asp-controller="Profile" asp-action="Settings" class="btn btn-outline-primary w-100">
                            <i class="bi bi-pencil-square me-2"></i> Editar Perfil
                        </a>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title text-muted small text-uppercase ls-1">Información Empresarial</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label mb-1 text-muted">Razón Social</label>
                            <div class="fw-bold">@Model.BusinessName</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label mb-1 text-muted">Cédula Jurídica</label>
                            <div class="font-monospace">@Model.LegalId</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label mb-1 text-muted">Plan Actual</label>
                            @if(Model.Plan.ToLower() == "pro" || Model.Plan.ToLower() == "enterprise") {
                                <div class="text-success fw-bold"><i class="bi bi-stars me-1"></i> @Model.Plan.ToUpper()</div>
                            } else {
                                <div class="text-secondary fw-bold">@Model.Plan.ToUpper()</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header">
                        <h3 class="card-title">Actividad Reciente</h3>
                        <div class="card-actions">
                            <a href="#" class="btn btn-sm btn-ghost-secondary" data-bs-toggle="modal" data-bs-target="#modal-activity-log">
                                <i class="bi bi-list-ul me-1"></i> Ver historial completo
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (Model.RecentActivities != null && Model.RecentActivities.Any())
                        {
                            <ul class="steps steps-vertical">
                                @foreach (var log in Model.RecentActivities.Take(7))
                                {
                                    <li class="step-item">
                                        <div class="h4 m-0">@log.Type</div>
                                        <div class="text-muted text-truncate">@log.Description</div>
                                        <span class="badge @log.ColorClass mt-2">
                                            @log.Timestamp.ToLocalTime().ToString("dd MMM yyyy - HH:mm")
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="empty">
                                <div class="empty-icon"><i class="bi bi-activity"></i></div>
                                <p class="empty-title">Sin actividad registrada</p>
                                <p class="empty-subtitle text-muted">
                                    Tus acciones recientes aparecerán aquí.
                                </p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

<div class="modal modal-blur fade" id="modal-activity-log" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Historial de Actividad</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table id="activityTable" class="table table-vcenter card-table table-striped" style="width:100%">
                        <thead>
                            <tr>
                                <th>Fecha y Hora</th>
                                <th>Acción</th>
                                <th>Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            var tableInitialized = false;
            var myModal = document.getElementById('modal-activity-log');

            myModal.addEventListener('shown.bs.modal', function () {
                if (!tableInitialized) {
                    $('#activityTable').DataTable({
                        "processing": true,
                        "serverSide": false,
                        "ajax": {
                            "url": "@Url.Action("GetActivityLog", "Profile")",
                            "type": "GET",
                            "datatype": "json"
                        },
                        "columns": [
                            { 
                                "data": "timestamp", 
                                "width": "25%",
                                "render": function(data) {
                                    if(!data) return "";
                                    
                                    if (!data.endsWith("Z")) {
                                        data += "Z";
                                    }
                                    
                                    var date = new Date(data);
                                    
                                    return date.toLocaleString('es-CR', {
                                        year: 'numeric', month: '2-digit', day: '2-digit',
                                        hour: '2-digit', minute: '2-digit', hour12: true
                                    });
                                }
                            },
                            { 
                                "data": "type",
                                "width": "20%",
                                "render": function(data) {
                                    if(!data) return "";
                                    var colorClass = "bg-blue-lt";
                                    var t = data.toLowerCase();
                                    
                                    if (t.includes("login") || t.includes("sesión")) colorClass = "bg-green-lt";
                                    else if (t.includes("crear") || t.includes("nuevo")) colorClass = "bg-azure-lt";
                                    else if (t.includes("eliminar") || t.includes("borrar")) colorClass = "bg-red-lt";
                                    else if (t.includes("restaurada") || t.includes("seguridad")) colorClass = "bg-orange-lt";
                                    
                                    return `<span class="badge ${colorClass}">${data}</span>`;
                                }
                            },
                            { "data": "description", "width": "55%" }
                        ],
                        "order": [[0, "desc"]], 
                        "language": {
                            "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                        },
                        "pageLength": 10,
                        "responsive": true,
                        "width": "100%"
                    });
                    tableInitialized = true;
                }
            });
        });
    </script>
}