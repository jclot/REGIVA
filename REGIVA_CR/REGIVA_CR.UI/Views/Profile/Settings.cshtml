@{
    Layout = "_Layout";
    ViewData["Title"] = "Configuración";
}

<div class="page-header">
    <div class="container-xl">
        <h2 class="page-title">Configuración</h2>
    </div>
</div>
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Seguridad y Cuenta</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" value="Administrador Principal">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <input type="password" class="form-control" placeholder="Dejar vacío para mantener">
                        </div>
                    </div>
                    <div class="card-footer text-end">
                        <button class="btn btn-primary">Guardar Cambios</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>