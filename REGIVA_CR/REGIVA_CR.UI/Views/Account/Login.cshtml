@using REGIVA_CR.AB.ModelosParaUI.Auth
@model LoginDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Iniciar Sesión - REGIVA</title>

    <script>
                (function () {
                    const theme = localStorage.getItem('app-theme') || 'auto';
                    if (theme === 'auto') {
                        document.documentElement.setAttribute('data-bs-theme', window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    } else {
                        document.documentElement.setAttribute('data-bs-theme', theme);
                    }
                })();
    </script>
    
    <link href="~/css/tabler.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <style>
        :root { --tblr-font-sans-serif: 'Inter', sans-serif; }
        
        .btn-back-home {
            transition: all 0.3s ease;
            font-weight: 500;
            color: #6c757d;
        }
        .btn-back-home:hover {
            color: var(--tblr-primary);
            text-decoration: none;
            transform: translateX(-5px);
        }

        .forgot-pass-link {
            color: #6c757d; 
            text-decoration: none;
            transition: color 0.2s ease;
            display: inline-flex;
            align-items: center;
        }
        .forgot-pass-link:hover {
            color: var(--tblr-primary);
            text-decoration: underline;
        }
    </style>
</head>
<body class="d-flex flex-column">
    <div class="page page-center">
        <div class="container container-tight py-4">
            
            <div class="mb-4">
                <a asp-controller="Landing" asp-action="Index" class="btn-back-home d-inline-flex align-items-center text-decoration-none">
                    <i class="bi bi-arrow-left me-2 fs-3"></i> 
                    <span>Volver al inicio</span>
                </a>
            </div>

            <div class="text-center mb-4">
                <a href="#" class="navbar-brand navbar-brand-autodark">REGIVA</a>
            </div>
            <div class="card card-md shadow-sm border-0"> 
                <div class="card-body">
                    <h2 class="h2 text-center mb-4">Bienvenido de nuevo</h2>
                    
                    <form asp-controller="Account" asp-action="Login" method="post" autocomplete="off">
                        
                        @if (ViewData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger" role="alert">
                                @ViewData["ErrorMessage"]
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label required"></label>
                            <input asp-for="Email" class="form-control" placeholder="usuario@empresa.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-2">
                            <label asp-for="Password" class="form-label required">
                                Contraseña
                                <span class="form-label-description">
                                    <a asp-action="ForgotPassword" class="forgot-pass-link" title="Recuperar acceso">
                                        <i class="bi bi-key me-1"></i> ¿Olvidaste tu contraseña?
                                    </a>
                                </span>
                            </label>
                            <div class="input-group input-group-flat">
                                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="off" />
                                <span class="input-group-text">
                                    <a href="#" class="link-secondary" onclick="togglePass()">👁</a>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-2">
                            <label class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <span class="form-check-label">Recordarme en este dispositivo</span>
                            </label>
                        </div>

                        <div class="form-footer">
                            <button type="submit" class="btn btn-primary w-100">Entrar</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="text-center text-muted mt-3">
                ¿No tienes cuenta? <a asp-action="Register" asp-route-restart="true" class="fw-bold text-primary">Regístrate gratis</a>
            </div>
        </div>
    </div>
    <script src="~/js/tabler.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePass() {
            var x = document.querySelector('input[name="Password"]');
            x.type = x.type === "password" ? "text" : "password";
        }
    </script>
</body>
</html>