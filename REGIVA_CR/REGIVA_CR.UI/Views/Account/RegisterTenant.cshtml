@using REGIVA_CR.AB.ModelosParaUI.Auth
@model TenantRegisterDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Datos de Empresa - REGIVA</title>

    <script>
                (function () {
                    const theme = localStorage.getItem('app-theme') || 'auto';
                    if (theme === 'auto') {
                        document.documentElement.setAttribute('data-bs-theme', window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    } else {
                        document.documentElement.setAttribute('data-bs-theme', theme);
                    }
                })();
    </script>

    <link href="~/css/tabler.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <style>
        :root { --tblr-font-sans-serif: 'Inter', sans-serif; }
        .btn-back-home {
            transition: all 0.3s ease;
            font-weight: 500;
            color: #6c757d;
        }
        .btn-back-home:hover {
            color: var(--tblr-danger); /* Rojo para indicar cancelación */
            text-decoration: none;
            transform: translateX(-5px);
        }
    </style>
</head>
<body class="d-flex flex-column">
    <div class="page page-center">
        <div class="container container-tight py-4">
            
            <div class="mb-4">
                <a asp-controller="Landing" asp-action="Index" class="btn-back-home d-inline-flex align-items-center text-decoration-none">
                    <i class="bi bi-x-lg me-2 fs-4"></i> 
                    <span>Cancelar registro</span>
                </a>
            </div>

            <div class="text-center mb-4">
                <a href="#" class="navbar-brand navbar-brand-autodark">REGIVA</a>
            </div>
            
            <form class="card card-md shadow-sm border-0" asp-controller="Account" asp-action="RegisterTenant" method="post" autocomplete="off">
                <div class="card-body">
                    <h2 class="card-title text-center mb-4">Paso 2: Datos de tu Negocio</h2>
                    
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="BusinessName" class="form-label required"></label>
                        <input asp-for="BusinessName" class="form-control" placeholder="Inversiones ABC S.A." />
                        <span asp-validation-for="BusinessName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LegalId" class="form-label required"></label>
                        <input asp-for="LegalId" class="form-control" placeholder="3101123456" />
                        <span asp-validation-for="LegalId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Phone" class="form-label required"></label>
                                <input asp-for="Phone" class="form-control" placeholder="88888888" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="EconomicActivityCode" class="form-label required"></label>
                                <div class="input-group input-group-flat">
                                    <input asp-for="EconomicActivityCode" type="password" class="form-control" placeholder="722003" autocomplete="off" />
                                    <span class="input-group-text">
                                        <a href="#" class="link-secondary" title="Mostrar código" onclick="togglePass('EconomicActivityCode'); return false;">👁</a>
                                    </span>
                                </div>
                                <span asp-validation-for="EconomicActivityCode" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" asp-for="SubscriptionPlan" value="basic" />

                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100">Finalizar y Crear Cuenta</button>
                    </div>
                </div>
            </form>
            
            <div class="text-center mt-3">
                <a asp-action="Register" class="text-muted">Volver al paso anterior</a>
            </div>
        </div>
    </div>
    <script src="~/js/tabler.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        function togglePass(fieldName) {
            var input = document.querySelector('input[name="' + fieldName + '"]');
            if (input) {
                input.type = input.type === "password" ? "text" : "password";
            }
        }
    </script>
</body>
</html>