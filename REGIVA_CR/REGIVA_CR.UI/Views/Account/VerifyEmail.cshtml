@using REGIVA_CR.AB.ModelosParaUI.Auth
@model VerifyEmailDto
@{ Layout = null; }

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Verificar Correo - REGIVA</title>
    <script>
                (function () {
                    const theme = localStorage.getItem('app-theme') || 'auto';
                    if (theme === 'auto') {
                        document.documentElement.setAttribute('data-bs-theme', window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    } else {
                        document.documentElement.setAttribute('data-bs-theme', theme);
                    }
                })();
    </script>
    <link href="~/css/tabler.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <style>
        :root { --tblr-font-sans-serif: 'Inter', sans-serif; }
        .letter-spacing-input { letter-spacing: 0.5em; font-weight: bold; text-align: center; font-size: 1.2rem; }
    </style>
</head>
<body class="d-flex flex-column">
    <div class="page page-center">
        <div class="container container-tight py-4">

            <div class="nav-item dropdown d-none d-md-flex me-3">
                <a href="#" class="nav-link px-0" data-bs-toggle="dropdown" tabindex="-1"                             aria-label="Cambiar tema">
                    <i class="bi bi-circle-half fs-4" id="theme-icon-active"></i>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                    <button class="dropdown-item theme-switch" data-theme="light">
                        <i class="bi bi-sun me-2"></i> Claro
                    </button>
                    <button class="dropdown-item theme-switch" data-theme="dark">
                        <i class="bi bi-moon-stars me-2"></i> Oscuro
                    </button>
                    <button class="dropdown-item theme-switch" data-theme="auto">
                        <i class="bi bi-circle-half me-2"></i> Automático (Sistema)
                    </button>
                </div>
            </div>

            <div class="text-center mb-4">
                <a href="#" class="navbar-brand navbar-brand-autodark">REGIVA</a>
            </div>
            
            <form class="card card-md shadow-sm border-0" asp-action="VerifyEmail" method="post" autocomplete="off">
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="avatar avatar-lg bg-blue-lt rounded-circle mb-3">
                            <i class="bi bi-envelope-check fs-1"></i>
                        </div>
                        <h2 class="card-title">Verifica tu correo</h2>
                        <p class="text-muted">
                            Hemos enviado un código de 6 dígitos y un enlace mágico a:
                            <br/><strong class="text-dark">@Model.Email</strong>
                        </p>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }
                    @if (TempData["InfoMessage"] != null)
                    {
                        <div class="alert alert-info">@TempData["InfoMessage"]</div>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label class="form-label text-center">Código de Verificación</label>
                        <input asp-for="Code" type="text" class="form-control letter-spacing-input" placeholder="000000" maxlength="6" inputmode="numeric" />
                        <span asp-validation-for="Code" class="text-danger small text-center d-block mt-1"></span>
                    </div>

                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100">Verificar Cuenta</button>
                    </div>
                </div>
            </form>
            
            <div class="text-center text-muted mt-3">
                ¿No recibiste el correo?
                <form asp-action="ResendVerification" method="post" class="d-inline">
                    <input type="hidden" name="email" value="@Model.Email" />
                    <button type="submit" class="btn btn-link p-0 align-baseline">Reenviar código</button>
                </form>
            </div>
            
            <div class="text-center mt-4">
                <a asp-action="Login" class="text-muted text-decoration-none small">
                    <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
                </a>
            </div>
        </div>
    </div>
    <script src="~/js/tabler.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        // Configuración del Theme Switcher
        const themeSwitches = document.querySelectorAll('.theme-switch');
        const activeIcon = document.getElementById('theme-icon-active');

        const updateIcon = (theme) => {
        if (theme === 'light') activeIcon.className = 'bi bi-sun fs-4';
        else if (theme === 'dark') activeIcon.className = 'bi bi-moon-stars fs-4';
        else activeIcon.className = 'bi bi-circle-half fs-4';
        };

        const setTheme = (theme) => {
        localStorage.setItem('app-theme', theme);
        if (theme === 'auto') {
        document.documentElement.setAttribute('data-bs-theme', window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        } else {
        document.documentElement.setAttribute('data-bs-theme', theme);
        }
        updateIcon(theme);
        };

        // Inicializar icono
        updateIcon(localStorage.getItem('app-theme') || 'auto');

        // Escuchar clicks
        themeSwitches.forEach(btn => {
        btn.addEventListener('click', () => {
        setTheme(btn.getAttribute('data-theme'));
        });
        });

        // Escuchar cambios del sistema (Windows/Mac) en tiempo real
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if ((localStorage.getItem('app-theme') || 'auto') === 'auto') {
        setTheme('auto');
        }
        });
        });
    </script>
</body>
</html>