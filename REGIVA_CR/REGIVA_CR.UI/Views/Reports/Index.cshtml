@{
    Layout = "_Layout";
    ViewData["Title"] = "Reportes";
}

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">Reportes y Análisis</h2>
            </div>
            <div class="col-auto ms-auto">
                <a href="#" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-new-report">
                    <i class="bi bi-file-earmark-bar-graph me-1"></i>Generar
                </a>
            </div>
        </div>
    </div>
</div>
<div class="page-body">
    <div class="container-xl">
        <div class="row row-cards">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Historial</h3>
                    </div>
                    <div class="list-group list-group-flush">
                        <a href="#" class="list-group-item list-group-item-action flex-column align-items-start">
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="mb-1">Reporte Financiero Q4</h5>
                                <small>3 días</small>
                            </div>
                            <p class="mb-1 text-muted">PDF - 2.4 MB</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>